{
  "name": "@shadrin-v/engine",
  "version": "0.0.4",
  "type": "module",
  "description": "Headless 2.5D pallet packing engine (isomorphic TypeScript)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shadrin-V/Pallet-Packer.git",
    "directory": "packages/engine"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  }
}
